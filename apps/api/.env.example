# =============================================================================
# API NestJS — copie para apps/api/.env (ou use .env na raiz do monorepo)
# Nao inclua SSH_PWD, senhas de servidor ou chaves de producao neste arquivo.
# =============================================================================

PORT=3002
NODE_ENV=development

# Origem permitida no CORS (frontend)
APP_ORIGIN=http://127.0.0.1:3001

# Obrigatorio — boot falha se ausente
JWT_SECRET=gerar-com-openssl-rand-base64-32

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/angra_bpo?schema=public

STORAGE_PROVIDER=local
STORAGE_BUCKET=angra-bpo-local

# Leitor de nota fiscal por IA (vision). Vazio = fallback manual (NEEDS_REVIEW).
AI_VISION_PROVIDER=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o-mini
GEMINI_VISION_MODEL=gemini-1.5-flash

# OCR legado (Hugging Face) — opcional
HF_API_KEY=
HF_MODEL_OCR=
HF_MODEL_CLASSIFICATION=

# Criptografia LGPD (biometria facial) — Item 25
# BIOMETRIC_ENCRYPTION_KEY=gerar-chave-32-bytes-base64