// Prisma schema — bpo-angra (PostgreSQL)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN_PLATAFORMA
  OPERADOR_BPO
  GESTOR_EMPRESA
  FINANCEIRO_EMPRESA
}

enum EntryType {
  PAYABLE
  RECEIVABLE
  EXPENSE
  REVENUE
}

enum EntryStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PAID
  RECEIVED
  CANCELLED
}

enum DocumentStatus {
  UPLOADED
  NEEDS_REVIEW
  APPROVED
  REJECTED
}

enum ReconciliationStatus {
  IMPORTED
  SUGGESTED_MATCH
  RECONCILED
  DIVERGENT
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NoteType {
  NFE
  NFCE
  CUPOM
  BOLETO
  OUTRO
}

enum ExtractionSource {
  MANUAL
  AI
}

enum CashSessionStatus {
  OPEN
  CLOSED
}

enum CashEntryType {
  SALE
  IN
  OUT
  SANGRIA
  SUPRIMENTO
}

enum MessageDirection {
  IN
  OUT
}

enum NoteDirection {
  RECEBIDA
  EMITIDA
}

enum TaxObligationType {
  DAS
  DEFIS
  OUTRO
}

enum ObligationStatus {
  PENDENTE
  PAGO
  ATRASADO
}

enum EmployeeStatus {
  ATIVO
  FERIAS
  AFASTADO
  DESLIGADO
}

enum PayrollStatus {
  ABERTA
  FECHADA
  PAGA
}

enum EsocialStatus {
  PENDENTE
  ENVIADO
}

enum CorporateDocType {
  CONTRATO_SOCIAL
  CERTIFICADO_DIGITAL
  PROCURACAO
  ALVARA
  OUTRO
}

enum ExportFormat {
  XML
  CSV
  ZIP
}

enum ExportStatus {
  PENDENTE
  GERADO
  ENVIADO
}

enum StockMoveType {
  IN
  OUT
  ADJUST
}

enum OrderStatus {
  OPEN
  PAID
  CANCELLED
}

model Company {
  id        String   @id @default(cuid())
  legalName String
  tradeName String
  cnpj      String   @unique
  taxRegime String   @default("SIMPLES_NACIONAL")
  createdAt DateTime @default(now())
}

model User {
  id           String  @id @default(cuid())
  name         String
  email        String  @unique
  passwordHash String
  role         Role
  companyId    String?
  createdAt    DateTime @default(now())
}

model BankAccount {
  id        String   @id @default(cuid())
  companyId String
  bank      String
  branch    String
  number    String
  balance   Decimal  @db.Decimal(14, 2) @default(0)
  createdAt DateTime @default(now())

  @@index([companyId])
}

model FinancialEntry {
  id               String      @id @default(cuid())
  companyId        String
  type             EntryType
  status           EntryStatus @default(DRAFT)
  description      String
  counterpartyName String
  category         String      @default("")
  documentNumber   String      @default("")
  amount           Decimal     @db.Decimal(14, 2)
  issueDate        DateTime
  dueDate          DateTime
  paidDate         DateTime?
  createdAt        DateTime    @default(now())

  @@index([companyId])
  @@index([type])
}

model Document {
  id          String         @id @default(cuid())
  companyId   String
  type        String
  status      DocumentStatus @default(UPLOADED)
  supplier    String
  amount      Decimal        @db.Decimal(14, 2) @default(0)
  category    String         @default("")
  confidence  Int            @default(0)
  source      ExtractionSource @default(MANUAL)
  storagePath String?
  uploadedAt  DateTime       @default(now())

  @@index([companyId])
}

model BankTransaction {
  id            String               @id @default(cuid())
  companyId     String
  bankAccountId String
  date          DateTime
  description   String
  amount        Decimal              @db.Decimal(14, 2)
  status        ReconciliationStatus @default(IMPORTED)
  matchedEntryId String?
  divergence    Decimal              @db.Decimal(14, 2) @default(0)
  createdAt     DateTime             @default(now())

  @@index([companyId])
}

model ApprovalRequest {
  id          String         @id @default(cuid())
  companyId   String
  targetType  String
  targetId    String
  description String
  amount      Decimal        @db.Decimal(14, 2) @default(0)
  requestedBy String
  status      ApprovalStatus @default(PENDING)
  createdAt   DateTime       @default(now())

  @@index([companyId])
}

model AuditLog {
  id         String   @id @default(cuid())
  companyId  String
  entityType String
  entityId   String
  action     String
  actor      String
  createdAt  DateTime @default(now())

  @@index([companyId])
}

model Product {
  id           String   @id @default(cuid())
  companyId    String
  name         String
  barcode      String?
  unit         String   @default("UN")
  price        Decimal  @db.Decimal(14, 2) @default(0)
  cost         Decimal  @db.Decimal(14, 2) @default(0)
  stockQty     Decimal  @db.Decimal(14, 3) @default(0)
  minStock     Decimal  @db.Decimal(14, 3) @default(0)
  supplierId   String?
  category     String?
  sourceNoteId String?
  createdAt    DateTime @default(now())

  @@index([companyId])
}

model FiscalNote {
  id           String           @id @default(cuid())
  companyId    String
  direction    NoteDirection    @default(RECEBIDA)
  type         NoteType         @default(OUTRO)
  supplierName String?
  supplierCnpj String?
  customerName String?
  total        Decimal          @db.Decimal(14, 2) @default(0)
  issueDate    DateTime?
  status       DocumentStatus   @default(NEEDS_REVIEW)
  source       ExtractionSource @default(MANUAL)
  storagePath  String?
  rawText      String?
  posted       Boolean          @default(false)
  createdAt    DateTime         @default(now())
  items        NoteItem[]

  @@index([companyId])
}

model NoteItem {
  id          String     @id @default(cuid())
  noteId      String
  description String
  qty         Decimal    @db.Decimal(14, 3) @default(1)
  unitPrice   Decimal    @db.Decimal(14, 2) @default(0)
  total       Decimal    @db.Decimal(14, 2) @default(0)
  productId   String?
  note        FiscalNote @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@index([noteId])
}

model CashSession {
  id            String            @id @default(cuid())
  companyId     String
  openedBy      String
  openedAt      DateTime          @default(now())
  closedAt      DateTime?
  openingAmount Decimal           @db.Decimal(14, 2) @default(0)
  closingAmount Decimal?          @db.Decimal(14, 2)
  status        CashSessionStatus @default(OPEN)
  entries       CashEntry[]

  @@index([companyId])
}

model CashEntry {
  id            String        @id @default(cuid())
  sessionId     String
  type          CashEntryType
  amount        Decimal       @db.Decimal(14, 2)
  description   String?
  paymentMethod String?
  noteId        String?
  createdAt     DateTime      @default(now())
  session       CashSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model ChatThread {
  id            String        @id @default(cuid())
  companyId     String
  contactName   String
  contactPhone  String?
  lastMessageAt DateTime      @default(now())
  createdAt     DateTime      @default(now())
  messages      ChatMessage[]

  @@index([companyId])
}

model ChatMessage {
  id        String           @id @default(cuid())
  threadId  String
  direction MessageDirection
  body      String?
  mediaPath String?
  noteId    String?
  createdAt DateTime         @default(now())
  thread    ChatThread       @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
}

// Fornecedores cadastrados (auto-criados a partir das NFs recebidas).
model Supplier {
  id        String   @id @default(cuid())
  companyId String
  name      String
  cnpj      String?
  email     String?
  phone     String?
  category  String?
  createdAt DateTime @default(now())

  @@index([companyId])
}

// Clientes cadastrados que podem ser identificados por biometria/QR no caixa.
model Customer {
  id             String   @id @default(cuid())
  companyId      String
  name           String
  document       String?
  phone          String?
  email          String?
  // Descritor facial criptografado em repouso (AES) — dado sensivel LGPD art. 11.
  faceDescriptor String?
  // Consentimento explicito para coleta biometrica (data/hora UTC).
  biometricConsentAt DateTime?
  // Credencial WebAuthn (id base64) para digital/biometria de plataforma.
  webauthnCredId String?
  // Token estável embutido no QR Code do cliente.
  qrToken        String?  @unique
  creditLimit    Decimal  @db.Decimal(14, 2) @default(0)
  balance        Decimal  @db.Decimal(14, 2) @default(0)
  createdAt      DateTime @default(now())

  @@index([companyId])
}

// Movimentos de estoque (entrada por NF, saída por venda/caixa, ajuste manual).
model StockMovement {
  id        String        @id @default(cuid())
  companyId String
  productId String
  type      StockMoveType
  qty       Decimal       @db.Decimal(14, 3)
  reason    String?
  refType   String?
  refId     String?
  createdAt DateTime      @default(now())

  @@index([companyId])
  @@index([productId])
}

// Obrigações fiscais do Simples: DAS mensal, DEFIS anual e afins.
model TaxObligation {
  id          String            @id @default(cuid())
  companyId   String
  type        TaxObligationType @default(DAS)
  competence  String // "AAAA-MM" (DAS) ou "AAAA" (DEFIS)
  dueDate     DateTime
  amount      Decimal           @db.Decimal(14, 2) @default(0)
  baseRevenue Decimal           @db.Decimal(14, 2) @default(0)
  status      ObligationStatus  @default(PENDENTE)
  paidDate    DateTime?
  receiptPath String?
  notes       String?
  createdAt   DateTime          @default(now())

  @@index([companyId])
}

// Funcionários (folha/trabalhista, quando a empresa tem empregados).
model Employee {
  id            String         @id @default(cuid())
  companyId     String
  name          String
  cpf           String?
  role          String?
  admissionDate DateTime?
  salary        Decimal        @db.Decimal(14, 2) @default(0)
  status        EmployeeStatus @default(ATIVO)
  createdAt     DateTime       @default(now())
  payroll       PayrollEntry[]

  @@index([companyId])
}

// Competências de folha por funcionário (salário, FGTS, INSS, férias, eSocial).
model PayrollEntry {
  id            String        @id @default(cuid())
  companyId     String
  employeeId    String
  competence    String // "AAAA-MM"
  baseSalary    Decimal       @db.Decimal(14, 2) @default(0)
  fgts          Decimal       @db.Decimal(14, 2) @default(0)
  inss          Decimal       @db.Decimal(14, 2) @default(0)
  netPay        Decimal       @db.Decimal(14, 2) @default(0)
  vacationDue   Decimal       @db.Decimal(14, 2) @default(0)
  esocialStatus EsocialStatus @default(PENDENTE)
  status        PayrollStatus @default(ABERTA)
  createdAt     DateTime      @default(now())
  employee      Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([employeeId])
}

// Documentos societários: contrato social, certificados digitais, procurações.
model CorporateDoc {
  id          String           @id @default(cuid())
  companyId   String
  type        CorporateDocType @default(OUTRO)
  title       String
  issueDate   DateTime?
  expiryDate  DateTime?
  storagePath String?
  notes       String?
  createdAt   DateTime         @default(now())

  @@index([companyId])
}

// Vendas do PDV (frente de caixa). Toda venda paga é orquestrada em SalesService
// numa transação única: marca o pedido como PAID, gera o lançamento financeiro
// (RECEIVABLE), registra a venda no caixa (CashEntry SALE) e dá baixa de estoque
// (StockMovement OUT). mpPaymentId liga o pedido ao pagamento do Mercado Pago.
model Order {
  id            String      @id @default(cuid())
  companyId     String
  sessionId     String?
  customerId    String?
  number        Int         @default(0)
  status        OrderStatus @default(OPEN)
  subtotal      Decimal     @db.Decimal(14, 2) @default(0)
  discount      Decimal     @db.Decimal(14, 2) @default(0)
  total         Decimal     @db.Decimal(14, 2) @default(0)
  paymentMethod String?
  mpPaymentId   String?     @unique
  createdBy     String      @default("")
  createdAt     DateTime    @default(now())
  paidAt        DateTime?
  items         OrderItem[]

  @@index([companyId])
  @@index([sessionId])
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String?
  description String
  qty         Decimal @db.Decimal(14, 3) @default(1)
  unitPrice   Decimal @db.Decimal(14, 2) @default(0)
  total       Decimal @db.Decimal(14, 2) @default(0)
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

// Pacotes de exportação para o contador (XML/CSV/ZIP por competência).
model AccountingExport {
  id           String       @id @default(cuid())
  companyId    String
  competence   String // "AAAA-MM"
  format       ExportFormat @default(ZIP)
  status       ExportStatus @default(PENDENTE)
  notesCount   Int          @default(0)
  entriesCount Int          @default(0)
  payrollCount Int          @default(0)
  storagePath  String?
  generatedAt  DateTime?
  createdAt    DateTime     @default(now())

  @@index([companyId])
}
