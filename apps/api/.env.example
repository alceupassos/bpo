PORT=3002
NODE_ENV=development
APP_ORIGIN=http://127.0.0.1:3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/angra_bpo
JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too
STORAGE_PROVIDER=local
STORAGE_BUCKET=angra-bpo-local

# Leitor de nota fiscal por IA (vision). Vazio = fallback manual (NEEDS_REVIEW).
# AI_VISION_PROVIDER: openai | gemini | vazio (auto-detecta pela chave presente)
AI_VISION_PROVIDER=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o-mini
GEMINI_VISION_MODEL=gemini-1.5-flash

# OCR legado (Hugging Face) — opcional
HF_API_KEY=
HF_MODEL_OCR=
HF_MODEL_CLASSIFICATION=
