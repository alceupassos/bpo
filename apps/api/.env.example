# =============================================================================
# API NestJS — copie para apps/api/.env (ou use .env na raiz do monorepo)
# Nao inclua SSH_PWD, senhas de servidor ou chaves de producao neste arquivo.
# =============================================================================

PORT=3002
NODE_ENV=development

# Origem permitida no CORS (frontend)
APP_ORIGIN=http://127.0.0.1:3001

# Obrigatorio — boot falha se ausente
JWT_SECRET=gerar-com-openssl-rand-base64-32

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/angra_bpo?schema=public

STORAGE_PROVIDER=local
STORAGE_BUCKET=angra-bpo-local

# Leitor de nota fiscal por IA (vision). Vazio = fallback manual (NEEDS_REVIEW).
AI_VISION_PROVIDER=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o-mini
GEMINI_VISION_MODEL=gemini-1.5-flash

# OCR legado (Hugging Face) — opcional
HF_API_KEY=
HF_MODEL_OCR=
HF_MODEL_CLASSIFICATION=

# Criptografia LGPD (biometria facial) — Item 25
# BIOMETRIC_ENCRYPTION_KEY=gerar-chave-32-bytes-base64

# Copiloto de vendas / categorizacao (texto). Vazio = fallback heuristico.
AI_TEXT_PROVIDER=
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1
OPENAI_TEXT_MODEL=gpt-4o-mini

# Pagamentos do PDV — Mercado Pago. Vazio = pagamento manual (sem confirmacao automatica).
MP_ACCESS_TOKEN=
# URL publica que o Mercado Pago chama ao confirmar o pagamento (webhook):
MP_NOTIFICATION_URL=
# Opcional: segredo para validacao adicional do webhook
MP_WEBHOOK_SECRET=

# Emissao fiscal NFC-e/NF-e (Focus NFe). Vazio = emissao SIMULADA (cupom sem valor fiscal).
FOCUS_NFE_TOKEN=
FOCUS_NFE_ENV=homologacao

# Multi-gateway de pagamento. Provedor padrao quando o PDV nao escolhe um:
PAYMENT_PROVIDER=MERCADOPAGO
# Cada gateway: sem credencial = modo SIMULADO/manual (nunca trava).
ASAAS_API_KEY=
ASAAS_ENV=sandbox
ASAAS_CUSTOMER_ID=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAGBANK_TOKEN=
REDE_PV=
REDE_TOKEN=
INFINITYPAY_TOKEN=
INFINITYPAY_HANDLE=

# Pix estático (BR Code escaneável sem gateway). Vazio = modo simulado.
PIX_KEY=
PIX_MERCHANT_NAME=ANGRA BPO
PIX_MERCHANT_CITY=SAO PAULO