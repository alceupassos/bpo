# =============================================================================
# Angra BPO — variaveis de ambiente (copie para .env e preencha)
# NUNCA commite .env com valores reais. Credenciais de infra (SSH, etc.)
# ficam fora deste arquivo — use gerenciador de segredos ou .env local git-ignored.
# =============================================================================

# --- Banco (API NestJS) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/angra_bpo?schema=public

# --- Autenticacao (obrigatorio — API nao sobe sem JWT_SECRET) ---
JWT_SECRET=gerar-com-openssl-rand-base64-32

# --- Frontend Next.js ---
NEXT_PUBLIC_API_URL=http://127.0.0.1:3002/api
APP_ORIGIN=http://127.0.0.1:3001

# --- IA (opcional — vazio = fallback manual) ---
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# HF_API_KEY=